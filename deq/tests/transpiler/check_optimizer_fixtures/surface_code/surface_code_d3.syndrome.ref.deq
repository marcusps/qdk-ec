    CHECK OUT0.S2 M1
    CHECK OUT0.S3 M5
    CHECK OUT0.S4 M6
    CHECK OUT0.S5 M2
    CHECK OUT0.S6 M7
    CHECK OUT0.S7 M3
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0

