    CHECK M1 IN0.S2
    CHECK M5 IN0.S3
    CHECK M6 IN0.S4
    CHECK M2 IN0.S5
    CHECK M7 IN0.S6
    CHECK M3 IN0.S7
    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    CHECK OUT0.S0 M0
