@PTYPE(1)
CODE RepetitionCode [[3,1,1]] {
    LOGICAL X0*X1*X2 Z0
    STABILIZER Z0*Z1  # generator S0, destabilizer DS0=X1*X2
    STABILIZER Z1*Z2  # generator S1, destabilizer DS1=X2
    STABILIZER Z2*Z0
}

@GTYPE(1)
@CHECKS("manual", verify=0)
GADGET PrepareZ {
    R 0 1 2
    OUTPUT RepetitionCode 0 1 2
    CHECK OUT0.S0
    CHECK OUT0.S1
    CHECK OUT0.S2
    PROPAGATE OUT0.LZ0 FROM
    PROPAGATE OUT0.LX0 FROM

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 3
    #   weight distribution: { 1:3 }
    # errors: 0
}

@GTYPE(2)
@CHECKS("manual", verify=0)
GADGET MeasureZ {
    INPUT RepetitionCode 0 1 2
    M 0 1 2
    READOUT rec[-3]  # IN0.LX0
    CHECK M1 M0 IN0.S0
    CHECK M2 M1 IN0.S1
    CHECK M2 M0 IN0.S2

    # --- statistics ---
    # finished checks: 3
    #   weight distribution: { 3:3 }
    # unfinished checks: 0
    # errors: 0
}

@GTYPE(3)
@CHECKS("manual", verify=0)
GADGET AutomorphismIdentity {
    INPUT RepetitionCode 0 1 2
    OUTPUT RepetitionCode 2 1 0
    CHECK OUT0.S0 IN0.S1
    CHECK OUT0.S1 IN0.S0
    CHECK OUT0.S2 IN0.S2
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0 IN0.DS0 IN0.DS1

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 3
    #   weight distribution: { 2:3 }
    # errors: 0
}

@GTYPE(4)
@CHECKS("manual", verify=0)
GADGET Syndrome {
    INPUT RepetitionCode 0 2 4
    R 1 3
    CX 0 1 2 3
    CX 2 1 4 3
    M 1 3
    CHECK M0 IN0.S0
    CHECK M1 IN0.S1
    CHECK M1 M0 IN0.S2
    OUTPUT RepetitionCode 0 2 4
    CHECK OUT0.S0 M0
    CHECK OUT0.S1 M1
    CHECK OUT0.S2 M1 M0
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0

    # --- statistics ---
    # finished checks: 3
    #   weight distribution: { 2:2, 3:1 }
    # unfinished checks: 3
    #   weight distribution: { 2:2, 3:1 }
    # errors: 0
}

@GTYPE(5)
@CHECKS("manual", verify=0)
GADGET MultiSyndrome {
    INPUT RepetitionCode 0 2 4
    R 1 3
    CX 0 1 2 3
    CX 2 1 4 3
    M 1 3
    R 1 3
    CX 0 1 2 3
    CX 2 1 4 3
    M 1 3
    R 1 3
    CX 0 1 2 3
    CX 2 1 4 3
    M 1 3
    CHECK M0 IN0.S0
    CHECK M1 IN0.S1
    CHECK M1 M0 IN0.S2
    CHECK M4 M0
    CHECK M5 M1
    CHECK M4 M2
    CHECK M5 M3
    OUTPUT RepetitionCode 0 2 4
    CHECK OUT0.S0 M0
    CHECK OUT0.S1 M1
    CHECK OUT0.S2 M1 M0
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0

    # --- statistics ---
    # finished checks: 7
    #   weight distribution: { 2:6, 3:1 }
    # unfinished checks: 3
    #   weight distribution: { 2:2, 3:1 }
    # errors: 0
}

