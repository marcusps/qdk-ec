@GTYPE(3)
@CHECKS("manual", verify=0)
GADGET CX {
    INPUT Code422 0 1 2 3
    INPUT Code422 4 5 6 7
    CX 0 4 1 5 2 6 3 7
    OUTPUT Code422 0 1 2 3
    OUTPUT Code422 4 5 6 7
    CHECK OUT0.S0 IN1.S0 IN0.S0
    CHECK OUT0.S1 IN0.S1
    CHECK OUT1.S0 IN1.S0
    CHECK OUT1.S1 IN1.S1 IN0.S1
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0 IN1.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0
    PROPAGATE OUT0.LZ1 FROM IN0.LZ1 IN1.LZ1
    PROPAGATE OUT0.LX1 FROM IN0.LX1
    PROPAGATE OUT1.LZ0 FROM IN1.LZ0
    PROPAGATE OUT1.LX0 FROM IN0.LX0 IN1.LX0
    PROPAGATE OUT1.LZ1 FROM IN1.LZ1
    PROPAGATE OUT1.LX1 FROM IN0.LX1 IN1.LX1

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 4
    #   weight distribution: { 2:2, 3:2 }
    # errors: 0
}

@GTYPE(4)
@CHECKS("manual", verify=0)
GADGET Permute {
    INPUT Code422 0 1 2 3
    OUTPUT Code422 1 0 3 2
    CHECK OUT0.S0 IN0.S0
    CHECK OUT0.S1 IN0.S1
    PROPAGATE OUT0.LZ0 FROM IN0.LZ0
    PROPAGATE OUT0.LX0 FROM IN0.LX0 IN0.DS1
    PROPAGATE OUT0.LZ1 FROM IN0.LZ1 IN0.DS0
    PROPAGATE OUT0.LX1 FROM IN0.LX1

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 2
    #   weight distribution: { 2:2 }
    # errors: 0
}

@GTYPE(5)
@CHECKS("manual", verify=0)
GADGET MeasureZZ {
    INPUT Code422 0 1 2 3
    M 0 1 2 3
    READOUT rec[-4] rec[-2]  # IN0.LX0
    READOUT rec[-4] rec[-3]  # IN0.LX1

    # --- statistics ---
