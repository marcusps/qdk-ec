@PTYPE(1)
CODE Code422 [[4,2,2]] {
    LOGICAL X0*X1 Z0*Z2
    LOGICAL X0*X2 Z0*Z1
    STABILIZER X0*X1*X2*X3  # generator S0, destabilizer DS0=Z0*Z1*Z2
    STABILIZER Z0*Z1*Z2*Z3  # generator S1, destabilizer DS1=X3
}

@GTYPE(1)
@CHECKS("manual", verify=0)
GADGET PrepareXX {
    RX 0 1 2 3
    MPP Z0*Z1*Z2*Z3
    OUTPUT Code422 0 1 2 3
    CHECK OUT0.S0
    CHECK OUT0.S1 M0
    PROPAGATE OUT0.LZ0 FROM
    PROPAGATE OUT0.LX0 FROM
    PROPAGATE OUT0.LZ1 FROM
    PROPAGATE OUT0.LX1 FROM

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 2
    #   weight distribution: { 1:1, 2:1 }
    # errors: 0
}

@GTYPE(2)
@CHECKS("manual", verify=0)
GADGET PrepareZZ {
    R 0 1 2 3
    MPP X0*X1*X2*X3
    OUTPUT Code422 0 1 2 3
    CHECK OUT0.S0 M0
    CHECK OUT0.S1
    PROPAGATE OUT0.LZ0 FROM
    PROPAGATE OUT0.LX0 FROM
    PROPAGATE OUT0.LZ1 FROM
    PROPAGATE OUT0.LX1 FROM

    # --- statistics ---
